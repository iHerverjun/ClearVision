eters\": {\n        \"ExpectedLabels\": \"Wire_Brown,Wire_Black,Wire_Blue\",\n        \"SortBy\": \"CenterX\",\n        \"Direction\": \"Ascending\",\n        \"ExpectedCount\": \"3\",\n        \"MinConfidence\": \"0.5\"\n      }\n    },\n    {\n      \"tempId\": \"op_7\",\n      \"operatorType\": \"ResultOutput\",\n      \"displayName\": \"结果输出\",\n      \"parameters\": {\n        \"Format\": \"JSON\",\n        \"SaveToFile\": \"true\"\n      }\n    }\n  ],\n  \"connections\": [\n    {\n      \"sourceTempId\": \"op_1\",\n      \"sourcePortName\": \"Image\",\n      \"targetTempId\": \"op_2\",\n      \"targetPortName\": \"Image\"\n    },\n    {\n      \"sourceTempId\": \"op_2\",\n      \"sourcePortName\": \"Image\",\n      \"targetTempId\": \"op_3\",\n      \"targetPortName\": \"Image\"\n    },\n    {\n      \"sourceTempId\": \"op_3\",\n      \"sourcePortName\": \"Image\",\n      \"targetTempId\": \"op_4\",\n      \"targetPortName\": \"Image\"\n    },\n    {\n      \"sourceTempId\": \"op_4\",\n      \"sourcePortName\": \"Objects\",\n      \"targetTempId\": \"op_5\",\n      \"targetPortName\": \"Detections\"\n    },\n    {\n      \"sourceTempId\": \"op_4\",\n      \"sourcePortName\": \"Image\",\n      \"targetTempId\": \"op_5\",\n      \"targetPortName\": \"Image\"\n    },\n    {\n      \"sourceTempId\": \"op_5\",\n      \"sourcePortName\": \"Detections\",\n      \"targetTempId\": \"op_6\",\n      \"targetPortName\": \"Detections\"\n    },\n    {\n      \"sourceTempId\": \"op_5\",\n      \"sourcePortName\": \"Image\",\n      \"targetTempId\": \"op_7\",\n      \"targetPortName\": \"Image\"\n    },\n    {\n      \"sourceTempId\": \"op_6\",\n      \"sourcePortName\": \"Message\",\n      \"targetTempId\": \"op_7\",\n      \"targetPortName\": \"Result\"\n    }\n  ],\n  \"parametersNeedingReview\": {\n    \"op_2\": [\n      \"X\",\n      \"Y\",\n      \"Width\",\n      \"Height\"\n    ],\n    \"op_4\": [\n      \"ModelPath\",\n      \"LabelsPath\",\n      \"Confidence\"\n  
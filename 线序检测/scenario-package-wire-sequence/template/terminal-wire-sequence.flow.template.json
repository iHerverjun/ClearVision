{
  "name": "Terminal Wire Sequence Template",
  "description": "Full-image DeepLearning + ROI box filtering + BoxNms + DetectionSequenceJudge baseline.",
  "scenarioKey": "wire-sequence-terminal",
  "templateVersion": "1.4.0",
  "expectedSequence": [
    "Wire_Black",
    "Wire_Blue"
  ],
  "expectedDetectionCount": 2,
  "requiredResources": [
    "DeepLearning.ModelPath"
  ],
  "tunableParameters": [
    "BoxNms.ScoreThreshold",
    "BoxNms.IouThreshold"
  ],
  "operators": [
    {
      "id": "op_1",
      "type": "ImageAcquisition",
      "name": "Acquire"
    },
    {
      "id": "op_2",
      "type": "DeepLearning",
      "name": "WireRootDetection",
      "params": {
        "ModelPath": "",
        "LabelsPath": "",
        "Confidence": "0.05",
        "InputSize": "640",
        "TargetClasses": "Wire_Black,Wire_Blue",
        "EnableInternalNms": "false",
        "DetectionMode": "Object"
      }
    },
    {
      "id": "op_3",
      "type": "BoxFilter",
      "name": "RoiDetectionFilter",
      "params": {
        "FilterMode": "Region",
        "RegionX": "0",
        "RegionY": "0",
        "RegionW": "999999",
        "RegionH": "999999",
        "MinScore": "0.0"
      }
    },
    {
      "id": "op_4",
      "type": "BoxNms",
      "name": "DetectionNms",
      "params": {
        "IouThreshold": "0.45",
        "ScoreThreshold": "0.25",
        "MaxDetections": "10",
        "ShowSuppressed": "false"
      }
    },
    {
      "id": "op_5",
      "type": "DetectionSequenceJudge",
      "name": "SequenceJudge",
      "params": {
        "ExpectedLabels": "Wire_Black,Wire_Blue",
        "SortBy": "CenterY",
        "Direction": "TopToBottom",
        "ExpectedCount": "2",
        "MinConfidence": "0.0"
      }
    },
    {
      "id": "op_6",
      "type": "ResultOutput",
      "name": "Output",
      "params": {
        "Format": "JSON",
        "SaveToFile": "true"
      }
    }
  ],
  "connections": [
    {
      "source": "op_1",
      "sourcePort": "Image",
      "target": "op_2",
      "targetPort": "Image"
    },
    {
      "source": "op_2",
      "sourcePort": "Objects",
      "target": "op_3",
      "targetPort": "Detections"
    },
    {
      "source": "op_1",
      "sourcePort": "Image",
      "target": "op_3",
      "targetPort": "Image"
    },
    {
      "source": "op_3",
      "sourcePort": "Detections",
      "target": "op_4",
      "targetPort": "Detections"
    },
    {
      "source": "op_1",
      "sourcePort": "Image",
      "target": "op_4",
      "targetPort": "Image"
    },
    {
      "source": "op_4",
      "sourcePort": "Detections",
      "target": "op_5",
      "targetPort": "Detections"
    },
    {
      "source": "op_4",
      "sourcePort": "Image",
      "target": "op_6",
      "targetPort": "Image"
    },
    {
      "source": "op_4",
      "sourcePort": "Diagnostics",
      "target": "op_6",
      "targetPort": "Data"
    },
    {
      "source": "op_5",
      "sourcePort": "Diagnostics",
      "target": "op_6",
      "targetPort": "Result"
    },
    {
      "source": "op_5",
      "sourcePort": "Message",
      "target": "op_6",
      "targetPort": "Text"
    }
  ],
  "parametersNeedingReview": {
    "op_2": [
      "ModelPath"
    ],
    "op_3": [
      "RegionX",
      "RegionY",
      "RegionW",
      "RegionH"
    ],
    "op_4": [
      "ScoreThreshold",
      "IouThreshold"
    ],
    "op_5": [
      "ExpectedLabels",
      "ExpectedCount"
    ]
  }
}

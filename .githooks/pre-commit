#!/usr/bin/env bash
set -euo pipefail

changed_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if [[ -z "${changed_files}" ]]; then
  exit 0
fi

if ! echo "${changed_files}" | grep -Eq '^(Acme\.Product/src/Acme\.Product\.Infrastructure/Operators/|Acme\.Product/src/Acme\.Product\.Core/Attributes/|Acme\.Product/src/Acme\.Product\.Core/Enums/OperatorEnums\.cs|scripts/OperatorDocGenerator/)'; then
  exit 0
fi

echo "[pre-commit] Operator-related changes detected. Regenerating operator catalog..."

generator_dll=""
for candidate in \
  "scripts/OperatorDocGenerator/bin/Debug/net8.0/OperatorDocGenerator.dll" \
  "scripts/OperatorDocGenerator/bin/Release/net8.0/OperatorDocGenerator.dll"
do
  if [[ -f "${candidate}" ]]; then
    generator_dll="${candidate}"
    break
  fi
done

if [[ -n "${generator_dll}" ]]; then
  echo "[pre-commit] Using prebuilt generator: ${generator_dll}"
  dotnet "${generator_dll}" .
else
  echo "[pre-commit] Prebuilt generator not found. Falling back to dotnet run."
  dotnet run --project scripts/OperatorDocGenerator/OperatorDocGenerator.csproj -- .
fi

git add -- 'docs/算子资料' '算子资料'
echo "[pre-commit] Staged updated docs/算子资料 and 算子资料 outputs"
